{
  "name": "game-screen-foundry",
  "version": "0.1.0",
  "description": "Spec-driven local workbench for generating and assembling game screen assets.",
  "license": "MIT",
  "main": "electron/main.js",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/surugawan-ebi/game-screen-foundry.git"
  },
  "bugs": {
    "url": "https://github.com/surugawan-ebi/game-screen-foundry/issues"
  },
  "homepage": "https://github.com/surugawan-ebi/game-screen-foundry#readme",
  "keywords": [
    "game-ui",
    "game-assets",
    "screen-layout",
    "imagegen",
    "codex"
  ],
  "scripts": {
    "check": "npm run lint && npm run validate && npm test",
    "add-screen": "node scripts/add-screen.js",
    "desktop": "node scripts/start-electron.js",
    "desktop:dev": "node scripts/start-electron.js --devtools",
    "dev": "node server.js",
    "init-project": "node scripts/init-project.js",
    "lint": "node scripts/check-js-syntax.js",
    "postprocess:assets": "node scripts/postprocess-assets.js",
    "profile:reference": "node scripts/build-reference-quality-profile.js",
    "release:check": "npm run check && node scripts/check-local-paths.js && node scripts/check-tracked-imagegen.js",
    "skill:install": "node scripts/install-codex-skill.js",
    "structure:preview": "node scripts/structure-preview.js",
    "skill:install:claude": "node scripts/install-claude-skill.js",
    "validate": "node scripts/check-json.js && node scripts/check-skills.js && node scripts/validate-project-files.js",
    "validate:project": "node scripts/validate-project.js",
    "test": "node --test"
  },
  "devDependencies": {
    "electron": "^43.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
