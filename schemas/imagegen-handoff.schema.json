{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://surugawan-ebi.github.io/game-screen-foundry/schemas/imagegen-handoff.schema.json",
  "title": "Game Screen Foundry Imagegen Handoff v3",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "kind",
    "jobId",
    "screenId",
    "jobPath",
    "outputDir",
    "assets"
  ],
  "properties": {
    "schema": {
      "const": "game-screen-foundry.imagegen-handoff.v3"
    },
    "kind": {
      "const": "game-screen-foundry.imagegen-handoff"
    },
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "screenId": {
      "type": "string",
      "minLength": 1
    },
    "jobPath": {
      "type": "string",
      "minLength": 1
    },
    "outputDir": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jobAsset"
      }
    }
  },
  "$defs": {
    "inputImage": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "role"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": ["edit_target", "style_reference", "content_reference"]
        },
        "purpose": {
          "type": "string"
        }
      }
    },
    "generationContract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "assetId",
        "operation",
        "inputImages",
        "change",
        "preserve",
        "generationSize",
        "transparencyPlan",
        "postprocessPlan",
        "acceptanceChecks",
        "prompt"
      ],
      "properties": {
        "assetId": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "enum": ["generate", "edit", "variant"]
        },
        "inputImages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputImage"
          }
        },
        "change": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preserve": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "generationSize": {
          "type": "string",
          "pattern": "^[0-9]+x[0-9]+$"
        },
        "outputPath": {
          "type": "string"
        },
        "transparencyPlan": {
          "type": "object"
        },
        "postprocessPlan": {
          "type": "object"
        },
        "acceptanceChecks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "jobAsset": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "assetId",
        "generationSize",
        "outputPath",
        "generationContract",
        "qualityGate",
        "prompt"
      ],
      "properties": {
        "assetId": {
          "type": "string",
          "minLength": 1
        },
        "generationSize": {
          "type": "string",
          "pattern": "^[0-9]+x[0-9]+$"
        },
        "outputPath": {
          "type": "string",
          "minLength": 1
        },
        "generationContract": {
          "$ref": "#/$defs/generationContract"
        },
        "qualityGate": {
          "type": "object"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
